{
  "version": "2",
  "type": "frontend",
  "tech_stack": ["HTML5", "CSS3", "JavaScript (Vanilla)", "Vite"],
  "routes": [
    {
      "path": "/",
      "file": "index.html",
      "auth_required": false,
      "description": "Página principal de la tienda de smartphones"
    },
    {
      "path": "/src/pages/carrito.html",
      "file": "src/pages/carrito.html",
      "auth_required": false,
      "description": "Página del carrito de compras"
    },
    {
      "path": "/src/pages/contacto.html",
      "file": "src/pages/contacto.html",
      "auth_required": false,
      "description": "Página de contacto"
    }
  ],
  "features": [
    {
      "name": "Catálogo de Productos",
      "description": "Muestra una lista de smartphones con imagen, nombre, precio y botón de agregar al carrito",
      "files": ["index.html", "src/scripts/app.js"],
      "entry_route": "/",
      "user_interactions": [
        "Ver lista de productos en la página principal",
        "Hacer clic en botón Agregar para añadir producto al carrito",
        "Ver contador del carrito actualizado"
      ],
      "api_calls": [],
      "auth_required": false
    },
    {
      "name": "Carrito de Compras",
      "description": "Permite ver los productos seleccionados",
      "files": ["src/pages/carrito.html", "src/scripts/app.js"],
      "entry_route": "/src/pages/carrito.html",
      "user_interactions": [
        "Ver lista de productos en el carrito",
        "Ver total de la compra"
      ],
      "api_calls": [],
      "auth_required": false
    }
  ],
  "known_limitations": []
}
